APP_ENV=production

# Public URLs
FRONTEND_URL=https://lionsquad.at
PUBLIC_BACKEND_URL=https://lionsquad.at
CORS_ORIGINS=https://lionsquad.at

# Database
MONGO_URL=mongodb://mongodb:27017
DB_NAME=tls_arena

# Security
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
ADMIN_EMAIL=admin@lionsquad.at
ADMIN_PASSWORD=change-me-to-a-long-random-password

# Mail fallback. Main SMTP/Resend settings are managed in the admin UI.
SENDER_EMAIL=noreply@lionsquad.at
RESEND_API_KEY=

# Runtime
SEED_DEMO=false
DISABLE_SCHEDULER=false
UPLOAD_DIR=/app/backend/uploads

# Optional local-only escape hatch. Never enable in production.
ALLOW_INSECURE_CORS=false
